{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Metro (Expo)",
			"type": "shell",
			"command": "bun",
			"args": ["expo", "start"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Start Android",
			"type": "shell",
			"command": "bun",
			"args": ["expo", "start", "--android"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Start iOS (Metro only - open Simulator on host)",
			"type": "shell",
			"command": "bun",
			"args": ["expo", "start"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Start Web",
			"type": "shell",
			"command": "bun",
			"args": ["expo", "start", "--web"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Start Metro (Dev Client)",
			"type": "shell",
			"command": "bun",
			"args": ["expo", "start", "--dev-client"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build Android (Dev Client - container)",
			"type": "shell",
			"command": "bun",
			"args": ["expo", "run:android"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build iOS (Dev Client - macOS host)",
			"type": "shell",
			"command": "echo",
			"args": ["To build the iOS dev client on macOS without installing npm packages on the host:\n1. Run 'Prebuild iOS (Generate Native Code)' in the container\n2. On your Mac host, run: ./scripts/build-ios-host.sh\n\nThe script copies node_modules out of the running Podman devcontainer, runs CocoaPods on the host, opens Xcode, and cleans up when Xcode closes. Note: Expo's generated Podfile still invokes 'node' during pod install, so the host needs Xcode, CocoaPods, and a Node.js runtime."],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Prebuild (Generate Native Code)",
			"type": "shell",
			"command": "bun",
			"args": ["expo", "prebuild"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Prebuild Android (Generate Native Code)",
			"type": "shell",
			"command": "bun",
			"args": ["run", "prebuild:android"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Prebuild iOS (Generate Native Code)",
			"type": "shell",
			"command": "bun",
			"args": ["run", "prebuild:ios"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Connect Android Emulator",
			"type": "shell",
			"command": "bash",
			"args": ["./scripts/connect-android-emulator-host.sh"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "none",
			"presentation": {
				"echo": true,
				"reveal": "silent"
			}
		},
		{
			"label": "List Android Devices",
			"type": "shell",
			"command": "adb",
			"args": ["devices"],
			"options": {
				"cwd": "${workspaceFolder}/app"
			},
			"group": "none",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "shared"
			}
		}
	]
}
