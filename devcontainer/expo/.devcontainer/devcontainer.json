{
	"name": "Expo (React Native)",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"features": {
		"ghcr.io/devcontainers-extra/features/bun:1": {
			"version": "1.2.4"
		}
	},
	"forwardPorts": [8081, 19000, 19001, 19002, 19006],
	"portsAttributes": {
		"8081": {
			"label": "Metro Bundler",
			"visibility": "public"
		},
		"19000": {
			"label": "Expo Dev Tools",
			"visibility": "public"
		},
		"19001": {
			"label": "React Native Debugger",
			"visibility": "public"
		},
		"19002": {
			"label": "Expo Dev Client",
			"visibility": "public"
		},
		"19006": {
			"label": "Expo Web",
			"visibility": "public"
		}
	},
	"runArgs": [
		"--tmpfs=/tmp:rw,exec,nosuid,nodev,mode=1777",
		"--userns=keep-id",
		"--add-host=host.docker.internal:host-gateway",
		"--env-file",
		".devcontainer/.env"
	],
	"postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
	"postStartCommand": "bash .devcontainer/postStartCommand.sh",
	"initializeCommand": "bash .devcontainer/initializeCommand.sh",
	"customizations": {
		"vscode": {
			"extensions": ["biomejs.biome", "expo.vscode-expo-tools"],
			"settings": {
				"npm.packageManager": "bun",
				"terminal.integrated.defaultProfile.linux": "bash",
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "/bin/bash",
						"args": ["-l"]
					}
				}
			}
		}
	},
	"workspaceFolder": "/workspace",
	"mounts": [
		{
			"source": "${localWorkspaceFolder}",
			"target": "/workspace",
			"type": "bind"
		},
		{
			"source": "expo-node_modules",
			"target": "/workspace/app/node_modules",
			"type": "volume"
		}
	],
	"remoteUser": "node",
	"updateRemoteUserUID": true,
	"containerEnv": {
		"CHOKIDAR_USEPOLLING": "true"
	}
}
