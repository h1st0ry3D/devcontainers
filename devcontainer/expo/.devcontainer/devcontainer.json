{
    "name": "Expo (React Native)",
    "init": true,
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "features": {
        "ghcr.io/roul/devcontainer-features/mise:1": {
            "version": "2026.5.6"
        }
    },
    "forwardPorts": [8081, 19006],
    "containerEnv": {
        "ANDROID_HOME": "/home/node/.local/share/mise/installs/android-sdk/20.0",
        "ANDROID_SDK_ROOT": "/home/node/.local/share/mise/installs/android-sdk/20.0",
        "ANDROID_USER_HOME": "/home/node/.android",
        "REACT_NATIVE_PACKAGER_HOSTNAME": "localhost",
        "GRADLE_USER_HOME": "/workspace/.gradle",
        "MISE_CACHE_DIR": "/home/node/.cache/mise",
        "MISE_DATA_DIR": "/home/node/.local/share/mise",
        "MISE_STATE_DIR": "/home/node/.local/state/mise",
        "MISE_TRUSTED_CONFIG_PATHS": "/workspace",
        "NODE_EXTRA_CA_CERTS": "/workspace/secrets/certs/ca.crt",
        "PIP_DISABLE_PIP_VERSION_CHECK": "1",
        "PIP_NO_CACHE_DIR": "1",
        "PIP_REQUIRE_VIRTUALENV": "true"
    },
    "remoteEnv": {
        "PATH": "${containerEnv:PATH}:/home/node/.local/share/mise/shims:${containerEnv:ANDROID_HOME}/cmdline-tools/20.0/bin:${containerEnv:ANDROID_HOME}/platform-tools"
    },
    "portsAttributes": {
        "8081": {
            "label": "Metro Bundler",
            "visibility": "public"
        },
        "19006": {
            "label": "Expo Web",
            "visibility": "public"
        }
    },
    "runArgs": [
        "--name=expo",
        "--userns=keep-id:uid=1000,gid=1000",
        "--security-opt=no-new-privileges:true",
        "--cap-drop=NET_ADMIN",
        "--cap-drop=SYS_ADMIN",
        "--cap-drop=SYS_PTRACE",
        "--cap-drop=SYS_MODULE",
        "--cap-drop=DAC_READ_SEARCH",
        "--cap-drop=AUDIT_WRITE",
        "--tmpfs=/tmp:rw,exec,nosuid,nodev,mode=1777",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "initializeCommand": [
        "bash",
        "-lc",
        "mkdir -p \"${localWorkspaceFolder}/.cache\" \"${localWorkspaceFolder}/.gradle\" \"${localWorkspaceFolder}/app/node_modules\" && if command -v xattr >/dev/null 2>&1; then xattr -dr user.containers.override_stat \"${localWorkspaceFolder}\" 2>/dev/null || true; fi"
    ],
    "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "biomejs.biome",
                "expo.vscode-expo-tools",
                "ms-python.python",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "npm.packageManager": "bun",
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash",
                        "args": ["-l"]
                    }
                }
            }
        }
    },
    "workspaceFolder": "/workspace",
    "mounts": [
        {
            "source": "${localWorkspaceFolder}",
            "target": "/workspace",
            "type": "bind"
        },
        "source=${localWorkspaceFolder}/.devcontainer,target=/workspace/.devcontainer,type=bind,readonly",
        {
            "source": "${localWorkspaceFolderBasename}-mise-data",
            "target": "/home/node/.local/share/mise",
            "type": "volume"
        },
        {
            "source": "${localWorkspaceFolderBasename}-mise-cache",
            "target": "/home/node/.cache/mise",
            "type": "volume"
        },
        {
            "source": "${localWorkspaceFolderBasename}-mise-state",
            "target": "/home/node/.local/state/mise",
            "type": "volume"
        },
        {
            "source": "expo-vscode-server-${devcontainerId}",
            "target": "/home/node/.vscode-server",
            "type": "volume"
        }
    ],
    "remoteUser": "node",
    "updateRemoteUserUID": false
}
