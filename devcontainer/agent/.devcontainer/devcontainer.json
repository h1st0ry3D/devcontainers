{
  "name": "Agent Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "forwardPorts": [],
  "postCreateCommand": "bash .devcontainer/postCreateCommand.sh && sudo chown -R $(id -u):$(id -g) .",
  "remoteUser": "linuxbrew",
  "containerUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "anomalyco.opencode",
        "cdervis.vscode-pi"
      ]
    }
  }
}